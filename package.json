{
    "name": "code-gloss",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "format": "prettier --write --ignore-path .gitignore .",
        "start": "next start",
        "start:database": "docker compose up --wait --detach",
        "database:migrations": "docker exec postgresql psql --dbname \"host=localhost port=5432 user=username password=password123 dbname=postgres\" --file=/tmp/scripts/migrations.sql",
        "seed:database:pg": "docker exec postgresql psql --dbname \"host=localhost port=5432 user=username password=password123 dbname=postgres\" --file=/tmp/seeds/gloses_seeds.sql",
        "seed:database:ts": "npx ts-node infra/database/seeds/create_gloses_and_seeds.ts",
        "lint": "eslint .",
        "lint:fix": "eslint --fix --cache .",
        "test": "vitest --exclude \"*/integration-tests\" --exclude \"**/__tests__/infra/**\"",
        "test:db": "vitest --config vitest.config.db.mts",
        "test:integration": "npx playwright test",
        "test:coverage": "vitest --coverage",
        "test:watch": "npm run test -- --watch",
        "type-check": "npx tsc --build "
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "npm run format",
            "npm run lint:fix"
        ],
        "*.{json,html,yml}": [
            "npm run format"
        ]
    },
    "dependencies": {
        "@tailwindcss/postcss": "^4.3.1",
        "@types/pg": "^8.20.0",
        "dotenv": "^17.4.2",
        "next": "^16.2.9",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.0",
        "@testcontainers/postgresql": "^12.0.3",
        "@testing-library/jest-dom": "^6.6.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "^4.1.10",
        "autoprefixer": "^10.5.0",
        "better-sqlite3": "^12.11.1",
        "eslint": "^10.7.0",
        "eslint-config-next": "16.2.10",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.8",
        "mysql": "^2.18.1",
        "mysql2": "^3.22.6",
        "oracledb": "^7.0.0",
        "pg-query-stream": "^4.16.0",
        "postcss": "^8.5.19",
        "prettier": "^3.9.5",
        "sqlite3": "^6.0.1",
        "tailwindcss": "^4.1.3",
        "tedious": "^20.0.0",
        "testcontainers": "^12.0.1",
        "typescript": "^7.0.2",
        "typescript-eslint": "^8.61.1",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.17"
    }
}
