{
    "name": "code-gloss",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "format": "prettier --write --ignore-path .gitignore .",
        "start": "next start",
        "start:database": "docker compose up --wait --detach",
        "create:database": "docker exec postgresql psql --dbname \"host=localhost port=5432 user=username password=password123 dbname=postgres\" --file=/tmp/scripts/create_gloses_table.sql",
        "seed:database:pg": "docker exec postgresql psql --dbname \"host=localhost port=5432 user=username password=password123 dbname=postgres\" --file=/tmp/scripts/gloses_seeds.sql",
        "seed:database:ts": "npx ts-node infra/database/scripts/create_gloses_and_seeds.ts",
        "lint": "eslint .",
        "lint:fix": "eslint --fix --cache .",
        "test": "vitest --exclude \"*/integration-tests\"",
        "test:integration": "npx playwright test",
        "test:coverage": "vitest --coverage",
        "type-check": "npx tsc --build "
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "npm run format",
            "npm run lint:fix"
        ],
        "*.{json,html,yml}": [
            "npm run format"
        ]
    },
    "dependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@types/pg": "^8.20.0",
        "dotenv": "^17.4.2",
        "next": "^16.2.6",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@testing-library/jest-dom": "^6.6.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.7.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.6",
        "autoprefixer": "^10.5.0",
        "better-sqlite3": "^12.10.0",
        "eslint": "^10.3.0",
        "eslint-config-next": "16.2.6",
        "eslint-config-prettier": "^10.1.1",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.4",
        "mysql": "^2.18.1",
        "mysql2": "^3.22.3",
        "oracledb": "^6.8.0",
        "pg-query-stream": "^4.14.0",
        "postcss": "^8.5.3",
        "prettier": "^3.8.3",
        "sqlite3": "^6.0.1",
        "tailwindcss": "^4.1.3",
        "tedious": "^19.2.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.53.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.17"
    }
}
